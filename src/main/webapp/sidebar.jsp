<li class="nav-item"><a href="${pageContext.request.contextPath}/dashboard" class="nav-link ${activeMenu=='dashboard'?'active':''}"><i class="nav-icon fas fa-chart-pie"></i><p>数据仪表盘</p></a></li>
<li class="nav-item"><a href="${pageContext.request.contextPath}/customer/list" class="nav-link ${activeMenu=='customer'?'active':''}"><i class="nav-icon fas fa-building"></i><p>${sessionScope.user.sales?'我的客户':'客户管理'}</p></a></li>
<c:if test="${not sessionScope.user.sales}"><li class="nav-item"><a href="${pageContext.request.contextPath}/contact/list" class="nav-link ${activeMenu=='contact'?'active':''}"><i class="nav-icon fas fa-address-book"></i><p>联系人管理</p></a></li><li class="nav-item"><a href="${pageContext.request.contextPath}/product/list" class="nav-link ${activeMenu=='product'?'active':''}"><i class="nav-icon fas fa-cubes"></i><p>产品管理</p></a></li></c:if>
